# Block postinstall scripts — the exact attack vector
ignore-scripts=true

# Don't install packages published less than 7 days ago
min-release-age=7

# Enforce the `engines` field so `npm install` / `yarn install` are rejected.
# Because ignore-scripts blocks a preinstall `only-allow` guard, this is what
# actually forces everyone onto pnpm. (pnpm only validates `engines.node` and
# `engines.pnpm`, so the bogus npm/yarn entries don't affect it.)
engine-strict=true
