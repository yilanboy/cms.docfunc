{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc"
  ],
  "categories": {
    "correctness": "error"
  },
  "rules": {},
  "env": {
    "builtin": true
  },
  "overrides": [
    {
      "files": ["**/*.svelte"],
      "rules": {
        "no-unassigned-vars": "off"
      }
    }
  ]
}